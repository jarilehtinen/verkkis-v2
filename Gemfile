# frozen_string_literal: true

source 'https://rubygems.org'

# Verkkis vaatii Ruby 3.0+ (testattu 4.0:lla). curses ei enää kuulu
# standardikirjastoon, joten se asennetaan erikseen.
ruby '>= 3.0'

# TUI-piirtäminen (curses irrotettiin stdlibistä Ruby 3.5:ssä)
gem 'curses', '~> 1.6'

# Tuotelinkkien avaaminen selaimessa
gem 'launchy', '~> 3.0'
